            <!-- Tabs Content -->
            <div class="tab-content" id="installationTabContent">
                <!-- Windows Instructions -->
                <div class="tab-pane fade" id="windows" role="tabpanel" aria-labelledby="windows-tab">
                    <div class="p-3">
                        <h5>Windows Installation</h5>
                        <div class="code-card">
                            <pre>
# Via winget package manager
> winget install foks</pre>
                        </div>
                    </div>
                </div>

                <!-- macOS Instructions -->
                <div class="tab-pane fade" id="macos" role="tabpanel" aria-labelledby="macos-tab">
                    <div class="p-3">
                        <h5>macOS Installation</h5>
                        <div class="code-card">
                            <pre>
$ brew install foks</pre>
                        </div>
                        <p class="mt-3">
Uses <a href="https://brew.sh">homebrew</a>, with precompiled
binary signed by 
the FOKS developers (<a href="https://ne43.com">NE43 INC (L2W77ZPF94)</a>).
Signing allows password-free access to <i>foks</i>
macOS keychain items. Without it, you'd have to enter multiple
administrator passwords on every upgrade.
                        </p>
                    </div>
                </div>

                <!-- Linux Debian Instructions -->
                <div class="tab-pane fade" id="linux-debian" role="tabpanel" aria-labelledby="linux-debian-tab">
                    <div class="p-3">
                        <h5>Debian Installation</h5>
                        <div class="code-card">
                            <pre>
{{#shcom}}# For first time installation...{{/shcom}}
$ curl -fsSL  https://pkgs.foks.pub/install.sh  | sh

{{#shcom}}# For subsequent installs after apt sources are in place:{{/shcom}}
$ apt-get install foks</pre>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="linux-ubuntu" role="tabpanel" aria-labelledby="linux-ubuntu-tab">
                    <div class="p-3">
                        <h5>Ubuntu Installation</h5>
                        <div class="code-card">
                            <pre>
{{#shcom}}# For first time installation...{{/shcom}}
$ curl -fsSL  https://pkgs.foks.pub/install.sh  | sh

{{#shcom}}# For subsequent installs after apt sources are in place:{{/shcom}}
$ apt-get install foks</pre>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="linux-fedora" role="tabpanel" aria-labelledby="linux-fedora-tab">
                    <div class="p-3">
                        <h5>Fedora Linux Installation</h5>
                        <div class="code-card">
                            <pre>
{{#shcom}}# For first time installation...{{/shcom}}
$ curl -fsSL https://pkgs.foks.pub/install.sh  | sh

{{#shcom}}# For subsequent installs after apt sources are in place:{{/shcom}}
$ dnf install foks</pre>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="linux-arch" role="tabpanel" aria-labelledby="linux-arch-tab">
                    <div class="p-3">
                        <h5>Arch Linux Installation</h5>
                        <div class="code-card">
                            <pre>
# Works via AUR
$ yay -Sy go-foks</pre>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="linux-static" role="tabpanel" aria-labelledby="linux-static-tab">
                    <div class="p-3">
                        <h5>Static Linux Binary</h5>
                        <div class="code-card">
                            <pre>
{{#shcom}}# Will not auto-update...{{/shcom}}
$ curl -fsSL https://pkgs.foks.pub/install-static.sh  | sh</pre>
                        </div>
                    </div>
                </div>

                <!-- Source Instructions -->
                <div class="tab-pane fade show active" id="source" role="tabpanel" aria-labelledby="source-tab">
                    <div class="p-3">
                        <h5>Build from Source</h5>
                        <p>
                            To build FOKS from source, you will need a relatively-modern
                            <a href="https://go.dev">Go</a>
                            installation (1.23 or later). CGO is required to build SQLite.
                        </p>
                        <div class="code-card">
                            <pre>
$ go install github.com/foks-proj/go-foks/client/foks@latest
$ (cd $(dirname $(which foks)) && ln -s foks git-remote-foks)
$ foks ctl start</pre>
                        </div>
                    </div>
                </div>

                <!-- Server Instructions -->
                <div class="tab-pane fade" id="server" role="tabpanel" aria-labelledby="server-tab">
                    <div class="p-3">
                        <h5>Server</h5>
                        <p>
                           BYO VM (via cloud-provider) or bare-metal server. Requires <a href="https://docker.io">docker-compose</a>.
                        </p>
                        <div class="code-card">
                            <pre>
$ /usr/bin/env bash &lt;(curl -fsSL https://pkgs.foks.pub/server-install.sh)</pre>
                        </div>
                        <p class="mt-3">
                          Or you can build the above from source:
                        </p>
                        <div class="code-card">
                            <pre>
$ go install github.com/foks-proj/go-foks/server/foks-tool@latest
$ foks-tool standup --interactive
$ docker-compose up -d</pre>
                        </div>
                    </div>
                </div>

            </div>
